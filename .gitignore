# .gitignore

# Ignore Python cache files
__pycache__
*.pyc
*.pyo
*.pyd

# Ignore log files
logs/

# Ignore any environment variables or secrets (if any)
venv
.env
.secrets

# Ignore any database files (if any)
*.db
*.sqlite3

# Ignore operating system files
.DS_Store  # macOS
Thumbs.db  # Windows

# Claude Code
.claude/

# Ignore unnecessary files for website functionality
tree_structure.sh
generate_resume_pdf.py
generate_resume.py
output.txt

